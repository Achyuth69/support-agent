# ── LLM Provider ─────────────────────────────────────
# Choose one: groq | gemini | openai
LLM_PROVIDER=groq

# ── Groq ──────────────────────────────────────────────
GROQ_API_KEY=gsk_...
# Models: llama-3.3-70b-versatile | mixtral-8x7b-32768 | gemma2-9b-it
LLM_MODEL=llama-3.3-70b-versatile

# ── Gemini ────────────────────────────────────────────
# GROQ_API_KEY=  (leave blank if using Gemini)
# GEMINI_API_KEY=AIza...
# LLM_MODEL=gemini-1.5-pro
# Models: gemini-1.5-pro | gemini-1.5-flash | gemini-2.0-flash

# ── OpenAI (fallback) ─────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# ── Salesforce ────────────────────────────────────────
SF_USERNAME=your@email.com
SF_PASSWORD=yourpassword
SF_SECURITY_TOKEN=yourtoken
SF_DOMAIN=login   # use 'test' for sandbox

# ── Zendesk ───────────────────────────────────────────
ZENDESK_SUBDOMAIN=yourcompany
ZENDESK_EMAIL=agent@yourcompany.com
ZENDESK_API_TOKEN=your_zendesk_api_token

# ── Twilio WhatsApp ───────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Email (SMTP) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ── SLA (minutes) ─────────────────────────────────────
SLA_RESPONSE_TIME=60
SLA_RESOLUTION_TIME=480

# ── Escalation ────────────────────────────────────────
ESCALATION_WEBHOOK_URL=https://your-slack-or-teams-webhook-url

# ── Redis (optional, for persistent memory) ───────────
REDIS_URL=redis://localhost:6379/0
